# Required: create .env.local (never commit it)
GROQ_API_KEY=your_groq_api_key_here

# Required on Vercel/serverless: in-memory sessions do not persist across invocations.
# Create a free Redis at https://upstash.com and paste REST credentials:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx

# Optional overrides
# GROQ_SIMPLE_MODEL=llama-3.1-8b-instant
# GROQ_COMPLEX_MODEL=llama-3.3-70b-versatile
